{
  "mcpServers": {
    "playwright": {
      "type": "stdio",
      "command": "cmd",
      "args": ["/c", "npx @playwright/mcp@latest"]
    },
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp"
    },
    "sequential-thinking": {
      "command": "cmd",
      "args": ["/c", "npx -y @modelcontextprotocol/server-sequential-thinking"]
    },
    "shadcn": {
      "command": "cmd",
      "args": ["/c", "npx shadcn@latest mcp"]
    },
    "shrimp-task-manager": {
      "command": "cmd",
      "args": [
        "/k",
        "node C:/Users/LEE/workspace/mcp-shrimp-task-manager/dist/index.js"
      ],
      "env": {
        "DATA_DIR": "C:/Users/LEE/workspace/courses/invoice-web/shrimp_data",
        "TEMPLATES_USE": "en",
        "ENABLE_GUI": "true"
      }
    }
  }
}
