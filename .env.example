# Invoice Web 환경변수 설정 가이드
# 개발 환경: .env.local 파일 생성 후 설정 (커밋 금지)
# 배포 환경: Vercel 대시보드 → Environment Variables에서 설정

# ============================================================
# 필수 변수 (프로덕션 배포 필수)
# ============================================================

# Notion API 인증 키
# 생성: https://notion.so/my-integrations → Create new integration
# 형식: secret_aAbBcCdDeEfFgGhHiIjJkKlLmMnNoOpPqQrRsT (36자 이상)
NOTION_API_KEY=secret_your_notion_api_key_here

# Notion 견적서 데이터베이스 ID
# 추출: DB URL에서 [DATABASE_ID] 부분 복사
# 형식: 3290c100-3d2e-80e2-a7b3-d8ad3c344811 (UUID, 하이픈 포함)
NOTION_DATABASE_ID=your_database_id_here

# NextAuth.js JWT 서명 비밀키
# 생성: openssl rand -base64 32
# 길이: 32자 이상 (Base64 인코딩)
AUTH_SECRET=your_auth_secret_here

# ============================================================
# 선택 변수 (개발/테스트 환경, 프로덕션에서는 생략)
# ============================================================

# 테스트 계정 이메일 (E2E 테스트용)
AUTH_TEST_EMAIL=test@example.com

# 테스트 계정 비밀번호 (E2E 테스트용)
AUTH_TEST_PASSWORD=test-password-123

# ============================================================
# 기타 설정 (선택)
# ============================================================

# 개발 환경 지정
NODE_ENV=development

# 애플리케이션 URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# 애플리케이션 이름
APP_NAME=Invoice Web
